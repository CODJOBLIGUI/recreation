# Clé secrète de Django (OBLIGATOIRE en production)
# Générer une nouvelle clé ici : https://djecrety.ir/
SECRET_KEY=django-insecure-fallback-key-for-development

# Mode DEBUG (NE JAMAIS mettre à True en production)
# Laisser vide pour 'development', mettre 'production' pour la production
DJANGO_ENV=development

# Hôtes autorisés (séparés par une virgule pour la production)
# Exemple : ALLOWED_HOSTS=mondomaine.com,www.mondomaine.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données (PostgreSQL en production) ---
# Ces valeurs ne sont utilisées qu'en mode 'production'
DB_NAME=editions_recreation
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_ici
DB_HOST=localhost
DB_PORT=5432

